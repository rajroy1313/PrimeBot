
{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/dashboard/(.*)",
      "dest": "/public/dashboard/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/website.js"
    },
    {
      "src": "/(.*)",
      "dest": "/website.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "index.js": {
      "maxDuration": 30
    },
    "website.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/dashboard/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/dashboard/index.html"
    }
  ]
}
