
{
  "version": 2,
  "builds": [
    {
      "src": "website.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/dashboard/(.*)",
      "dest": "/public/dashboard/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/website.js"
    },
    {
      "src": "/(.*)",
      "dest": "/website.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "website.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/public/dashboard/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/public/dashboard/index.html"
    }
  ]
}
